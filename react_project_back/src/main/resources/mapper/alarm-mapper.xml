<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="kr.co.iei.alarm.model.dao.AlarmDao">
	<update id="alarmAllCheck">
		update alarm_tbl set alarm_check = 1 where member_id = #{memberId}
	</update>
	<select id="selectAllAlarm" resultType="Alarm">
		select * from alarm_tbl where member_id = #{memberId}
	</select>
</mapper>
